  role_title                                  String?
  entity_name                                 String?
  entity_level                                String?
  rationale                                   String?
  created_at                                  DateTime?               @default(now()) @db.Timestamp(6)
  reports_to                                  Int?
  opportunity_candidates                      opportunity_candidates? @relation(fields: [opportunity_id], references: [id], onUpdate: NoAction, map: "fk_stakeholders_v2_opportunity")
  persons_stakeholders_v2_person_idTopersons  persons                 @relation("stakeholders_v2_person_idTopersons", fields: [person_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  persons_stakeholders_v2_reports_toTopersons persons?                @relation("stakeholders_v2_reports_toTopersons", fields: [reports_to], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([person_id, company_id, opportunity_id, gate_role], map: "stakeholders_v2_person_id_company_id_opportunity_id_gate_role_k")
  @@index([company_id], map: "idx_stakeholders_v2_company_id")
  @@index([opportunity_id], map: "idx_stakeholders_v2_opportunity_id")
  @@index([person_id], map: "idx_stakeholders_v2_person_id")
